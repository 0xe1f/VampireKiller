# Copyrighted game data - never committed (regenerate with tools/split-rom.sh)
segments/*.bin

# ROM-derived graphics dumps - regenerate with `make gfx` (manifest is committed).
# PNGs (sprite sheets, minimaps) ARE tracked so they're viewable without a rebuild.
gfx/*.bin
gfx/*.txt
gfx/index.md

# Build output
*.rom

# Toolchain built from source (see README)
tools/sjasmplus

# Local reference clones / scratch
references/

# Temporarily generated files (disassembler scratch, etc.); never committed.
# Regenerate with tools/regen-seg.sh; fold the clean .generated.asm into segNN.asm.
generated/

# Python scratch
tools/__pycache__/
__pycache__/

# OS cruft
.DS_Store
